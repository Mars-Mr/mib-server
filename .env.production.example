# Production template — copy to `.env.production` on the server or map to platform secrets.
# Never commit `.env.production` with real values.

NODE_ENV=production

# All values below MUST be set with strong, unique secrets (see src/common/config/env.constants.ts).
JWT_SECRET=
PAYMENT_WEBHOOK_SECRET=
DATABASE_URL=mysql://USER:PASSWORD@db-host:3306/mib_server
REDIS_PASSWORD=
MYSQL_ROOT_PASSWORD=

JWT_EXPIRES_IN=7d
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=mib

# Keep 0 in production — do not expose full API docs on the public internet
SWAGGER_ENABLED=0
LOG_LEVEL=info

# Only if you must enable docs on an internal network:
# SWAGGER_ENABLED=1
# SWAGGER_INTERNAL_ONLY=1
# SWAGGER_BASIC_USER=
# SWAGGER_BASIC_PASSWORD=

# Optional
# MYSQL_PASSWORD=
