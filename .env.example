DATABASE_URL="mysql://root:password@localhost:3306/mib_server"
JWT_SECRET="change_me_in_production"
NODE_ENV="development"
LOG_LEVEL="debug"
# 写入所有日志 JSON 的 service / version（便于集中检索）
LOG_SERVICE_NAME="mib-server"
APP_VERSION="0.0.1"
# 请求耗时超过该毫秒数时写入 app 通道一条 slow_http_request（并标记 access.slow）
HTTP_SLOW_REQUEST_MS="2000"
# Winston 日志目录（相对进程 cwd）
LOG_DIR="logs"
# 页面访问次数汇总写入 page-visit 日志的 cron（默认每 5 分钟）
PAGE_VISIT_FLUSH_CRON="*/5 * * * *"
# 单文件上限、保留天数、是否压缩归档
LOG_MAX_SIZE="20m"
LOG_MAX_FILES="14d"
LOG_ZIP_ARCHIVE="0"
# 设为 1 时输出 Prisma SQL 到 app 日志（仅建议开发环境）
PRISMA_LOG_QUERIES="0"
# Swagger：UI 路径前缀、是否启用（0/false 关闭）、文档主机名（启动日志用）
SWAGGER_PATH="api-docs"
SWAGGER_ENABLED="1"
SWAGGER_HOST="localhost"

# Redis（与 docker-compose.yml 中 redis 服务的 requirepass 一致）
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_USERNAME=""
REDIS_PASSWORD="change_me_in_production"
REDIS_DB="0"
REDIS_KEY_PREFIX="mib"
REDIS_CONNECT_TIMEOUT_MS="10000"
REDIS_COMMAND_TIMEOUT_MS="5000"
REDIS_MAX_RETRIES_PER_REQUEST="3"
REDIS_ENABLE_READY_CHECK="1"
REDIS_RETRY_BASE_DELAY_MS="200"
REDIS_RETRY_MAX_DELAY_MS="5000"
# Empty in production means retry reconnect forever; development defaults to 5 attempts.
REDIS_RETRY_MAX_ATTEMPTS=""

# MySQL Docker
MYSQL_IMAGE="mysql:latest"
MYSQL_PORT="3306"
MYSQL_ROOT_PASSWORD="password"
MYSQL_DATABASE="mib_server"
MYSQL_USER="mib_user"
MYSQL_PASSWORD="mib_password"
