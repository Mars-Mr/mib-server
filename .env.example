# Copy to `.env` for local development only.
# Production: use `.env.production` (see `.env.production.example`) or your platform's secret manager.
# Do NOT commit files containing real secrets.

NODE_ENV=development

# --- Production required (>= 32 chars for JWT / PAYMENT_WEBHOOK_SECRET) ---
# Leave JWT_SECRET unset in development → dev-only in-process fallback (blocked in production).
# JWT_SECRET=
# PAYMENT_WEBHOOK_SECRET=

DATABASE_URL=mysql://root:YOUR_LOCAL_DB_PASSWORD@localhost:3306/mib_server

JWT_EXPIRES_IN=7d
AUTH_LOGIN_MAX_ATTEMPTS=10
AUTH_LOGIN_WINDOW_SECONDS=900
# Lock account after N consecutive failures (5–15 min lock: 300–900 seconds)
AUTH_LOGIN_LOCK_AFTER_FAILURES=5
AUTH_LOGIN_LOCK_SECONDS=900

LOG_LEVEL=debug
LOG_SERVICE_NAME=mib-server
APP_VERSION=0.0.1
HTTP_SLOW_REQUEST_MS=2000
LOG_DIR=logs
PAGE_VISIT_FLUSH_CRON=*/5 * * * *
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_ZIP_ARCHIVE=0
PRISMA_LOG_QUERIES=0

SWAGGER_PATH=api-docs
# Development only — production defaults to SWAGGER_ENABLED=0 (see .env.production.example)
SWAGGER_ENABLED=1
SWAGGER_HOST=localhost
# Optional in dev; required when SWAGGER_ENABLED=1 in production
# SWAGGER_BASIC_USER=
# SWAGGER_BASIC_PASSWORD=
# Production + Swagger: defaults to 1 (private IPs only). Set 0 only if docs sit behind VPN + auth at edge.
# SWAGGER_INTERNAL_ONLY=0

# Redis (must match docker-compose / your Redis instance)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=YOUR_LOCAL_REDIS_PASSWORD_MIN_16
REDIS_DB=0
REDIS_KEY_PREFIX=mib
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_COMMAND_TIMEOUT_MS=5000
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_ENABLE_READY_CHECK=1
REDIS_RETRY_BASE_DELAY_MS=200
REDIS_RETRY_MAX_DELAY_MS=5000
REDIS_RETRY_MAX_ATTEMPTS=

# MySQL Docker (local only)
MYSQL_IMAGE=mysql:8.0.36
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=YOUR_LOCAL_MYSQL_ROOT_MIN_16
MYSQL_DATABASE=mib_server
MYSQL_USER=mib_user
MYSQL_PASSWORD=YOUR_LOCAL_MYSQL_APP_PASSWORD
